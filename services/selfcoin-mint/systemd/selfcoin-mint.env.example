SELFCOIN_MINT_HOST=127.0.0.1
SELFCOIN_MINT_PORT=8080
SELFCOIN_MINT_STATE_FILE=/var/lib/selfcoin-mint/state.json
SELFCOIN_MINT_MINT_ID=
SELFCOIN_MINT_SIGNING_SEED=selfcoin-mint-prod-seed
SELFCOIN_MINT_OPERATOR_KEY=dev-operator:1111111111111111111111111111111111111111111111111111111111111111
SELFCOIN_MINT_LIGHTSERVER_URL=http://127.0.0.1:19444/rpc
SELFCOIN_MINT_RESERVE_PRIVKEY=
SELFCOIN_MINT_RESERVE_ADDRESS=
SELFCOIN_MINT_RESERVE_FEE=1000
SELFCOIN_MINT_CLI_PATH=/opt/selfcoin-core/build/selfcoin-cli
SELFCOIN_MINT_NOTIFIER_RETRY_INTERVAL_SECONDS=5
SELFCOIN_MINT_SECRET_BACKEND=auto
SELFCOIN_MINT_NOTIFIER_SECRETS_FILE=
SELFCOIN_MINT_NOTIFIER_SECRET_DIR=/etc/selfcoin-mint/secrets.d
SELFCOIN_MINT_NOTIFIER_SECRET_ENV_PREFIX=SELFCOIN_MINT_SECRET_
SELFCOIN_MINT_NOTIFIER_SECRET_HELPER_CMD=
SELFCOIN_MINT_WORKER_LOCK_FILE=/run/selfcoin-mint/worker.lock
SELFCOIN_MINT_WORKER_STALE_TIMEOUT_SECONDS=30
